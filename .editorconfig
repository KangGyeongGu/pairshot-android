root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
# Single source of truth for ktlint + detekt-formatting (both consume this file).
# Pinned to ktlint 0.50.0 (matching detekt-formatting 1.23.7).
ktlint_code_style = android_studio
max_line_length = 140

# Project policy: function names sometimes use Compose-style PascalCase, so the
# function-naming rule must stay disabled.
ktlint_standard_function-naming = disabled

# Allow underscored backing properties (e.g. _state / state) used in ViewModels.
ktlint_standard_property-naming = disabled

# Compose-style trailing lambdas + multi-line constructor parameters: keep the
# project default (one-per-line via trailing comma), do not force same-line.
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Explicit import layout: third-party (alphabetical), then java, javax, kotlin,
# then star-imports/aliases. Matches detekt-formatting's ImportOrdering rule.
ij_kotlin_imports_layout = *,java.**,javax.**,kotlin.**,^

[*.md]
trim_trailing_whitespace = false
